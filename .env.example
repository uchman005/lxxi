# MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=

# ZeptoMail — token must include the "Zoho-enczapikey " prefix
# The sending domain (lxxi.africa) must be verified in ZeptoMail.
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_URL=api.zeptomail.com/

# Email "from" and internal notification recipient
MAIL_FROM=noreply@lxxi.africa
MAIL_FROM_NAME=LXXI Limited
MAIL_NOTIFY_TO=business@lxxi.africa

# NextAuth / Auth.js — generate with: npx auth secret
AUTH_SECRET=
